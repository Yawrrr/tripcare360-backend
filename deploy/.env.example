# NOTE: with CI/CD active you normally never touch .env by hand — the GitHub
# Actions workflow regenerates it on the VM from repo secrets on every deploy.
# This template is only for manual/local runs. NEVER commit .env.

# Image to run; CI sets this to the GHCR tag it just built. Leave unset for
# a local `docker compose up -d --build`.
#WEBAPI_IMAGE=ghcr.io/yawrrr/tripcare360-webapi:latest

# Root domain — subdomains api.<DOMAIN> and files.<DOMAIN> are derived from it
DOMAIN=tripcare360.me

# Azure SQL connection string (from the Azure portal / CLI output)
SQL_CONNECTION_STRING=Server=tcp:<your-sql-server>.database.windows.net,1433;Initial Catalog=TripCare360Db;User ID=<sql-admin-user>;Password=<sql-admin-password>;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# Generate a fresh long random string (do NOT reuse the one from appsettings.Local.json)
JWT_SECRET=

# Public URL of the already-hosted external mock server (kept secret here)
EXTERNAL_SERVICES_BASE_URL=

# MinIO credentials — pick new strong values for production
MINIO_ACCESS_KEY=tripcareAdmin
MINIO_SECRET_KEY=

# Mailpit UI (https://mail.<DOMAIN>) is gated by HTTP Basic Auth. Generate
# the hash with: docker run --rm caddy:2 caddy hash-password --plaintext '<password>'
MAILPIT_USER=admin
MAILPIT_PASSWORD_HASH=
